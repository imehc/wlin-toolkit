{
  "name": "wlin-toolkit",
  "version": "0.3.0",
  "description": "A JavaScript toolkit for WebAssembly integration with Rust",
  "main": "pkg/wlin_toolkit.js",
  "scripts": {
    "build:npm": "rimraf pkg && wasm-pack build && npm run pre",
    "build:ui": "wasm-pack build --target bundler && astro build",
    "build": "npm run build:npm",
    "dev": "wasm-pack build && astro dev",
    "preview": "astro preview",
    "test": "cargo test && wasm-pack test --headless",
    "pre": "sh prepublish.sh"
  },
  "devDependencies": {
    "@astrojs/node": "^10.1.4",
    "@tailwindcss/typography": "^0.5.20",
    "@tailwindcss/vite": "^4.3.1",
    "@types/node": "^26.0.0",
    "astro": "^6.4.8",
    "daisyui": "^5.5.23",
    "rimraf": "^6.1.3",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "vite-plugin-top-level-await": "^1.6.0",
    "vite-plugin-wasm": "^3.6.0"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@astrojs/mdx": "^6.0.3",
    "@astrojs/react": "^5.0.7",
    "@astrojs/svelte": "^8.1.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "svelte": "^5.56.3"
  }
}
